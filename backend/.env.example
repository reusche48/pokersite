PORT=4000
NODE_ENV=development
# Secreto para firmar los JWT: cadena larga y aleatoria (obligatorio en prod)
JWT_SECRET=change_me_to_a_long_random_string

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pokersite

# ── Seguridad / despliegue ──
# Contraseña del admin inicial (si no se define, se genera una aleatoria de un
# solo uso al arrancar y se muestra en el log). NUNCA dejar "admin123".
ADMIN_EMAIL=admin@pokersite.com
ADMIN_PASSWORD=
# Nº de proxies delante de la app (Railway/Nginx = 1). Hace que req.ip sea la IP
# real y no una X-Forwarded-For falsificada (clave para el anti-multicuenta).
TRUST_PROXY_HOPS=1
# Orígenes permitidos por CORS en producción (separados por coma). Vacío = '*'.
ALLOWED_ORIGINS=
# URL pública de la app (para los enlaces de recuperación de contraseña).
APP_URL=

# ── Escala (opcional, solo para multi-instancia) ──
# Si se define, habilita el adapter de Redis de Socket.io (ver OPERACIONES.md).
REDIS_URL=

# ── Pasarelas de pago (solo si algún día hay dinero real) ──
CULQI_SECRET_KEY=
CULQI_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
